# plAIground Configuration Template

# Use this file to configure your environment. Copy it to `.env` before use.

# Server hostname (used by stack-overview and n8n)
PLAIGROUND_HOST=localhost

## Local Ollama Settings
# Set to false to disable the local Ollama integration in Open WebUI
ENABLE_OLLAMA_API=true
# The internal address for the ollama container
OLLAMA_API_BASE_URL=http://ollama:11434

## External API Settings (e.g., LM Studio, OpenAI)
# If you provide a URL here, Open WebUI will AUTOMATICALLY enable the OpenAI-compatible mode.
# For LM Studio on Windows/Host, use: http://host.docker.internal:1234/v1
OPENAI_API_BASE_URL=

# API Key for external services (e.g., 'lm-studio' or actual OpenAI key)
OPENAI_API_KEY=

## Open WebUI Security & Auth
# Set to true to enable user registration and login
WEBUI_AUTH=false
# A secure random string for session management
# Generate with: openssl rand -base64 24
WEBUI_SECRET_KEY=

## Other Service Configs
# SearXNG Secret (Random string)
# Generate with: openssl rand -base64 24
SEARXNG_SECRET=
# PostgreSQL/Valkey URL
SEARXNG_VALKEY_URL=valkey://valkey:6379

## n8n
# https://docs.n8n.io/hosting/configuration/environment-variables/
# Network & Protocol
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_SECURE_COOKIE=false

# Encryption key – REQUIRED.
# Generate with: openssl rand -base64 24
N8N_ENCRYPTION_KEY=

# Instance Owner (auto-provisioned on first start)
# To generate a password hash, run:
#   docker run --rm node:20-alpine sh -c "cd /tmp && npm install bcryptjs && node -e \"const bcryptjs = require('bcryptjs'); console.log(bcryptjs.hashSync('YOUR_PASSWORD', 10))\""
# Current default password: admin
N8N_INSTANCE_OWNER_MANAGED_BY_ENV=true
N8N_INSTANCE_OWNER_EMAIL=admin@local.lan
N8N_INSTANCE_OWNER_FIRST_NAME=admin
N8N_INSTANCE_OWNER_LAST_NAME=admin
N8N_INSTANCE_OWNER_PASSWORD_HASH='$2b$10$FZGM2/dHjF8T9S7MKMorLunrjYdbfNMiJXn2mapp8Xi3c0vgsI/Pa'
